```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Database files
*.db

# Environment files
.env
.env.local
*.env.*

# Logs
*.log

# Coverage reports
.coverage
htmlcov/
coverage/

# Temporary files
*.tmp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Dependencies
venv/
.venv/
.env/
node_modules/

# Build artifacts
dist/
build/
target/
*.egg-info/

# Editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Testing
.pytest_cache/
.mypy_cache/
.hypothesis/

# Compression
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```